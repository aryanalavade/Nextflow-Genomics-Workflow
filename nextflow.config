workDir = '/tmp/nf-work'

dag {
    enabled   = true
    overwrite = true
    file      = "results/pipeline_info/dag.png"
}
report {
    enabled   = true
    overwrite = true
    file      = "results/pipeline_info/report.html"
}
timeline {
    enabled   = true
    overwrite = true
    file      = "results/pipeline_info/timeline.html"
}
trace {
    enabled   = true
    overwrite = true
    file      = "results/pipeline_info/trace.txt"
}

params {
    reads      = "${projectDir}/assets/data/test/*_{R1,R2}.fastq.gz"
    outdir     = "results"
    max_cpus   = Runtime.runtime.availableProcessors()
    max_memory = '8.GB'
}

process {
    cpus   = { Math.min(2, params.max_cpus as int) }
    memory = params.max_memory
}

profiles {
    conda {
        conda.enabled  = true
        conda.useMamba = true
    }

    test {
        params.reads      = "${projectDir}/assets/data/test/*_{R1,R2}.fastq.gz"
        params.max_memory = '4.GB'
    }
}
