trace.overwrite = true
workDir = '/tmp/nf-work'

params {
    reads     = "${projectDir}/assets/data/test/*_{R1,R2}.fastq.gz"
    outdir    = "results"
    max_cpus  = Runtime.runtime.availableProcessors()
    max_memory = '8.GB'
}

process {
    cpus   = { Math.min(2, params.max_cpus as int) }
    memory = params.max_memory
}

profiles {
    conda {
        conda.enabled  = true
        conda.useMamba = true
    }

    test {
        params.reads      = "${projectDir}/assets/data/test/*_{R1,R2}.fastq.gz"
        params.max_memory = '4.GB'
    }
}
